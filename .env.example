# 复制此文件到 .env(本地) 或在 Vercel 项目设置里逐项添加(生产)

# 本地开发:SQLite,什么都不用改
DATABASE_URL="file:./dev.db"

# 生产(Vercel + Neon Postgres):
# DATABASE_URL="postgresql://USER:PASS@HOST/DBNAME?sslmode=require"

# NextAuth 密钥(生产必须改成长随机串,可以用 `openssl rand -base64 32`)
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# 生产填你的 Vercel 域名,例如 https://aiug.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# 管理员邮箱白名单(用这些邮箱注册的账号自动获得 admin 权限)
ADMIN_EMAILS="admin@aiug.local"

# 生产文件存储:Vercel Blob(在 Vercel 项目里创建 Blob Store 后会自动注入此变量)
# BLOB_READ_WRITE_TOKEN=

